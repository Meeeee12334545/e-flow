# Version control
.git
.gitignore

# Python byte-code / caches
__pycache__
*.py[cod]
*.pyo
.pytest_cache
.mypy_cache

# Virtual environments
.venv
venv
env

# Local data files (mounted as volumes at runtime)
flow_data.db
*.db-shm
*.db-wal

# Log files (written at runtime)
*.log
monitor.log
supervisord.log

# Development / IDE
.devcontainer
.vscode
*.swp
*.swo

# Generated reports (written at runtime)
reports/*.pdf
reports/*.html

